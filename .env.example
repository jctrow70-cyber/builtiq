NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Service role — catalog import + bug report admin API (never expose in client code)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Comma-separated platform admin emails (Settings admin tools + bug report inbox)
BUILDIQ_ADMIN_EMAILS=you@example.com
# Legacy alias still supported:
# BUILDIQ_CATALOG_ADMIN_EMAILS=you@example.com
# Resend — email alerts when users submit bug reports (server only)
RESEND_API_KEY=your_resend_api_key
# Verified sender in Resend, e.g. BuildIQ Health <bugs@yourdomain.com>
BUILDIQ_EMAIL_FROM=BuildIQ Health <onboarding@resend.dev>
# Optional: override who receives bug report emails (defaults to BUILDIQ_ADMIN_EMAILS)
# BUILDIQ_BUG_REPORT_NOTIFY_EMAILS=you@example.com,teammate@example.com
# OpenAI — server-side AI program generation only (never expose in client code)
OPENAI_API_KEY=your_openai_api_key
# Optional model override (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
