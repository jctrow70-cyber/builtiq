NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Service role — catalog import API only (never expose in client code)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Comma-separated emails allowed to see Settings import + run POST /api/catalog/import-guided
BUILTIQ_CATALOG_ADMIN_EMAILS=you@example.com
# OpenAI — server-side AI program generation only (never expose in client code)
OPENAI_API_KEY=your_openai_api_key
# Optional model override (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
