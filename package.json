{
  "name": "build-iq-app-shell-strength-functional",
  "version": "1.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "import:exercises": "tsx scripts/import-exercises/importExercises.ts",
    "import:exercises:dry": "tsx scripts/import-exercises/importExercises.ts --dry-run",
    "import:exercises:production": "npm run import:convert:free-exercise-db && tsx scripts/import-exercises/importExercises.ts --enrich-legacy --file scripts/import-exercises/data/free-exercise-db/build-iq-import.json",
    "import:exercises:production:dry": "npm run import:convert:free-exercise-db && tsx scripts/import-exercises/importExercises.ts --dry-run --enrich-legacy --file scripts/import-exercises/data/free-exercise-db/build-iq-import.json",
    "import:fetch:exercisedb": "tsx scripts/import-exercises/fetchExerciseDb.ts --bulk",
    "import:fetch:exercisedb:api": "tsx scripts/import-exercises/fetchExerciseDb.ts",
    "import:exercises:exercisedb": "npm run import:fetch:exercisedb && tsx scripts/import-exercises/importExercises.ts --file scripts/import-exercises/data/exercisedb/build-iq-import.json",
    "import:exercises:exercisedb:dry": "npm run import:fetch:exercisedb && tsx scripts/import-exercises/importExercises.ts --dry-run --file scripts/import-exercises/data/exercisedb/build-iq-import.json",
    "import:alternatives": "tsx scripts/import-exercises/importAlternatives.ts",
    "import:alternatives:dry": "tsx scripts/import-exercises/importAlternatives.ts --dry-run",
    "import:convert:free-exercise-db": "tsx scripts/import-exercises/convertFreeExerciseDb.ts",
    "import:convert:spreadsheet": "tsx scripts/import-exercises/convertSpreadsheet.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "next": "^14.2.35",
    "openai": "^4.104.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.5.5",
    "@types/react": "^18.3.8",
    "@types/react-dom": "^18.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.2"
  }
}
